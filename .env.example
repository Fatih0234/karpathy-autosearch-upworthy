# Copy to .env and fill in your values
# cp .env.example .env

# Provider selection (heuristic | openai | gemini | openai_compat)
MODEL_PROVIDER=heuristic

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Gemini
GOOGLE_API_KEY=...
GEMINI_MODEL=gemini-2.5-flash-lite

# OpenAI-compatible endpoint (e.g. Ollama, vLLM, Together)
OPENAI_BASE_URL=http://localhost:11434/v1
