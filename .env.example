# Copy to .env and fill in your values
# cp .env.example .env

# Provider selection (heuristic | openai | gemini | openai_compat)
MODEL_PROVIDER=heuristic
AGENT_CLI=claude

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Gemini
GOOGLE_API_KEY=...
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_TIMEOUT_MS=15000
GEMINI_RETRY_ATTEMPTS=2

# OpenAI-compatible endpoint (e.g. Ollama, vLLM, Together)
OPENAI_BASE_URL=http://localhost:11434/v1

# Benchmark controls
EVAL_MAX_PAIRS=100
EVAL_WORKERS=3
